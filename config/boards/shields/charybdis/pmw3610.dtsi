/* PMW3610 Trackball Configuration - Native Zephyr Driver */
/* Previously used external badjeff driver with compatible = "pixart,pmw3610" */

#define INPUT_EV_REL 0x02               /* Relative coordinate event */
/* Previously: #include <zephyr/dt-bindings/input/input-event-codes.h> */

#define INPUT_REL_X 0x00                /* Relative X coordinate */
/* Previously: zephyr,axis-x = <INPUT_REL_X>; */
#define INPUT_REL_Y 0x01                /* Relative Y coordinate */
/* Previously: zephyr,axis-y = <INPUT_REL_Y>; */

&pinctrl {
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 8)>,
                <NRF_PSEL(SPIM_MOSI, 0, 17)>,
                <NRF_PSEL(SPIM_MISO, 0, 17)>;
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 8)>,
                <NRF_PSEL(SPIM_MOSI, 0, 17)>,
                <NRF_PSEL(SPIM_MISO, 0, 17)>;
            low-power-enable;
        };
    };
};

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 20 GPIO_ACTIVE_LOW>;

    trackball: trackball@0 {
        status = "okay";
        /* Previously: compatible = "pixart,pmw3610"; */
        compatible = "pixart,pmw3610-alt";
        reg = <0>;
        spi-max-frequency = <2000000>;
        irq-gpios = <&gpio0 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;

        /* Previously: res-cpi = <400>; */
        cpi = <800>;

        evt-type = <INPUT_EV_REL>;
        x-input-code = <INPUT_REL_X>;
        y-input-code = <INPUT_REL_Y>;

        /* Previously had: swap-xy; invert-x; invert-y; - removed, native driver handles */
        /* Previously had: force-awake; - removed, not supported by native driver */
    };
};

/* Previously: split_inputs and trackball_listener were defined here */
/* Moved to: split_input_common.dtsi */
