#include <zephyr/dt-bindings/input/input-event-codes.h>

/*
 * Trackball pin defaults — overridden by breakout_right.dtsi when the
 * right overlay includes it first. Left overlay disables &spi0 and
 * &trackball, so these defaults are inert there but must still resolve
 * for the dts compile to succeed.
 */
#ifndef R_PAD_TB_SCK_PORT
  #define R_PAD_TB_SCK_PORT    0
#endif
#ifndef R_PAD_TB_SCK_PIN
  #define R_PAD_TB_SCK_PIN     8
#endif
#ifndef R_PAD_TB_MOSI_PORT
  #define R_PAD_TB_MOSI_PORT   0
#endif
#ifndef R_PAD_TB_MOSI_PIN
  #define R_PAD_TB_MOSI_PIN   17
#endif
#ifndef R_PAD_TB_CS_PIN
  #define R_PAD_TB_CS_PIN     20
#endif
#ifndef R_PAD_TB_IRQ_PIN
  #define R_PAD_TB_IRQ_PIN     6
#endif

&pinctrl {
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK,  R_PAD_TB_SCK_PORT,  R_PAD_TB_SCK_PIN)>,
                <NRF_PSEL(SPIM_MOSI, R_PAD_TB_MOSI_PORT, R_PAD_TB_MOSI_PIN)>,
                <NRF_PSEL(SPIM_MISO, R_PAD_TB_MOSI_PORT, R_PAD_TB_MOSI_PIN)>;
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK,  R_PAD_TB_SCK_PORT,  R_PAD_TB_SCK_PIN)>,
                <NRF_PSEL(SPIM_MOSI, R_PAD_TB_MOSI_PORT, R_PAD_TB_MOSI_PIN)>,
                <NRF_PSEL(SPIM_MISO, R_PAD_TB_MOSI_PORT, R_PAD_TB_MOSI_PIN)>;
            low-power-enable;
        };
    };
};

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 R_PAD_TB_CS_PIN GPIO_ACTIVE_LOW>;

    trackball: trackball@0 {
        status = "okay";
        compatible = "pixart,pmw3610-alt";
        reg = <0>;
        spi-max-frequency = <2000000>;
        irq-gpios = <&gpio0 R_PAD_TB_IRQ_PIN (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;

        /* Use this value to change the trackball sensitivity */
        cpi = <900>;

        /* The below settings work best for the Charybdis sensor orientation */
            swap-xy;
            invert-x;
            invert-y;

        evt-type = <INPUT_EV_REL>;
        x-input-code = <INPUT_REL_X>;
        y-input-code = <INPUT_REL_Y>;
    };
};
