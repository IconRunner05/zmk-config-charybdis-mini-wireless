#include "charybdis-layouts.dtsi"
#include <dt-bindings/zmk/matrix_transform.h>

/ {

    vbatt: vbatt {
	compatible = "zmk,battery-nrf-vddh";
    };

    /*
     * Charybdis (Full, 4x6) matrix transform.
     *
     * Electrical row map:
     *   row 0 → pro_micro 18  (top main row,    physical TAB)
     *   row 1 → pro_micro  5  (         ,       physical ESC/home)
     *   row 2 → pro_micro  4  (         ,       physical LGUI/Z)
     *   row 3 → pro_micro  9  (thumb cluster)
     *   row 4 → pro_micro 15  (NEW number row, sits physically above row 0)
     *
     * `map` is listed in keymap-text order (top-to-bottom, left-to-right),
     * so the number row (RC(4,*)) appears first even though it is the last
     * electrical row.
     *
     * Thumb cluster (outer row long):
     *   Left (5 keys):           Right (3 keys):
     *       T1  T2  T3                T6  T7
     *           T4  T5                    T8
     *
     *   T1=(3,1) T2=(3,2) T3=(3,3) T4=(3,4) T5=(3,5)
     *   T6=(3,11) T7=(3,10) T8=(3,9)
     */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <5>;

        map = <
	RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5)  RC(4,11) RC(4,10) RC(4,9) RC(4,8) RC(4,7) RC(4,6)
	RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)  RC(0,11) RC(0,10) RC(0,9) RC(0,8) RC(0,7) RC(0,6)
	RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)  RC(1,11) RC(1,10) RC(1,9) RC(1,8) RC(1,7) RC(1,6)
	RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)  RC(2,11) RC(2,10) RC(2,9) RC(2,8) RC(2,7) RC(2,6)
	                RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)   RC(3,11) RC(3,10) RC(3,9)
        >;
    };

    five_column_transform: keymap_transform_1 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <5>;

        map = <
	RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5)  RC(4,10) RC(4,9) RC(4,8) RC(4,7) RC(4,6)
	RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)  RC(0,10) RC(0,9) RC(0,8) RC(0,7) RC(0,6)
	RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)  RC(1,10) RC(1,9) RC(1,8) RC(1,7) RC(1,6)
	RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)  RC(2,10) RC(2,9) RC(2,8) RC(2,7) RC(2,6)
	                RC(3,3) RC(3,4) RC(3,5)  RC(3,10) RC(3,9)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";

        diode-direction = "col2row";
		row-gpios
			= <&pro_micro 18 GPIO_ACTIVE_HIGH>
			, <&pro_micro 5 GPIO_ACTIVE_HIGH>
			, <&pro_micro 4 GPIO_ACTIVE_HIGH>
			, <&pro_micro 9 GPIO_ACTIVE_HIGH>
			, <&pro_micro 15 GPIO_ACTIVE_HIGH>
            ;
    };
};
